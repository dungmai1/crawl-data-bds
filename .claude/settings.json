{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(git push:*)",
      "Bash(git push)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push:*)",
            "command": "echo '{\"decision\":\"block\",\"reason\":\"Git push is not allowed unless explicitly requested by the user.\"}'",
            "statusMessage": "Checking git push permission..."
          }
        ]
      }
    ]
  }
}
